#!/usr/bin/env bash
set -euo pipefail

if [[ $# -eq 0 ]]; then
  dir="$PWD"
elif [[ $# -eq 1 ]]; then
  dir="$1"
else
  printf 'usage: tmx [DIR]\n' >&2
  exit 2
fi

if [[ ! -d "$dir" ]]; then
  printf 'tmx: not a directory: %s\n' "$dir" >&2
  exit 2
fi

dir="$(realpath "$dir")"

base="$(basename "$dir")"
base="${base//[^A-Za-z0-9._-]/-}"
[[ -z "$base" ]] && base="session"

hash="$(printf '%s' "$dir" | sha1sum | awk '{print $1}' | cut -c1-6)"
name="${base}-${hash}"

tmux has-session -t "$name" 2>/dev/null || tmux new-session -d -s "$name" -c "$dir"

if [[ -n "${TMUX-}" ]]; then
  tmux new-session -d -s "$name" -c "$dir" 2>/dev/null || true
  exec tmux switch-client -t "$name"
else
  exec tmux new-session -A -s "$name" -c "$dir"
fi
