#!/usr/bin/env bash
set -euo pipefail

mode="${1:-ls}"
case "$mode" in
  ls|ll) shift ;;
  *) mode="$(basename "$0")" ;;
esac

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
eza_bin=""

if command -v eza >/dev/null 2>&1; then
  eza_bin="$(command -v eza)"
elif [[ -x "$script_dir/eza" ]]; then
  eza_bin="$script_dir/eza"
fi

if [[ -n "$eza_bin" ]]; then
  case "$mode" in
    ll|buoy-ll) exec "$eza_bin" -la --git --ignore-glob=".git" "$@" ;;
    *) exec "$eza_bin" --tree --level=3 -la --git --ignore-glob=".git" "$@" ;;
  esac
fi

ls_bin="$(command -v ls)"

if "$ls_bin" --color=auto >/dev/null 2>&1; then
  exec "$ls_bin" --color=auto -la "$@"
fi

exec "$ls_bin" -la "$@"
