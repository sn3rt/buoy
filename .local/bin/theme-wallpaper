#!/usr/bin/env bash
set -euo pipefail

WALLPAPER_DIR="${WALLPAPER_DIR:-$HOME/Pictures/wallpapers}"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
THEME_DIR="$CONFIG_HOME/dots-theme"
KITTY_THEME="$THEME_DIR/kitty.conf"
HYPRLAND_THEME="$CONFIG_HOME/hypr/theme-wallpaper.conf"
QUICKSHELL_THEME="$CONFIG_HOME/quickshell/Theme.qml"
STATE_DIR="$STATE_HOME/dots-theme"

usage() {
  printf 'usage: theme-wallpaper [image]\n' >&2
}

set_wallpaper() {
  local image="$1"

  if command -v hyprpaper >/dev/null 2>&1 && ! pgrep -x hyprpaper >/dev/null 2>&1; then
    hyprpaper >/dev/null 2>&1 &
    sleep 0.2
  fi

  if hyprctl hyprpaper wallpaper ",$image,cover" >/dev/null 2>&1; then
    printf 'Wallpaper backend: hyprpaper\n'
    return 0
  fi

  if command -v swww >/dev/null 2>&1; then
    swww query >/dev/null 2>&1 || swww-daemon >/dev/null 2>&1 || true
    if swww img "$image" --resize crop >/dev/null 2>&1; then
      printf 'Wallpaper backend: swww\n'
      return 0
    fi
  fi

  if command -v swaybg >/dev/null 2>&1; then
    pkill -x swaybg >/dev/null 2>&1 || true
    swaybg -i "$image" -m fill >/dev/null 2>&1 &
    printf 'Wallpaper backend: swaybg\n'
    return 0
  fi

  printf 'theme-wallpaper: kitty colors updated, but no wallpaper backend is available.\n' >&2
  printf 'theme-wallpaper: install/start swww, hyprpaper, or swaybg to set the Hyprland wallpaper.\n' >&2
  return 1
}

apply_kitty_colors() {
  local socket_error=0

  if ! command -v kitty >/dev/null 2>&1; then
    printf 'theme-wallpaper: kitty command not found; colors written for future kitty sessions.\n' >&2
    return 0
  fi

  if [[ -n "${KITTY_LISTEN_ON-}" ]]; then
    if kitty @ --to "$KITTY_LISTEN_ON" set-colors --all --configured "$KITTY_THEME" >/dev/null 2>&1; then
      printf 'Kitty colors: live update via socket\n'
      return 0
    fi
    socket_error=1
  fi

  if [[ -n "${KITTY_WINDOW_ID-}" ]]; then
    if kitty @ set-colors --all --configured "$KITTY_THEME" >/dev/null 2>&1; then
      printf 'Kitty colors: live update via controlling terminal\n'
      return 0
    fi
  fi

  if [[ -z "${KITTY_LISTEN_ON-}" ]]; then
    printf 'theme-wallpaper: kitty colors written, but KITTY_LISTEN_ON is not set.\n' >&2
    printf 'theme-wallpaper: restart kitty once, then start a fresh shell/tmux session for live updates.\n' >&2
  elif [[ "$socket_error" -eq 1 ]]; then
    printf 'theme-wallpaper: kitty colors written, but live socket update failed: %s\n' "$KITTY_LISTEN_ON" >&2
  else
    printf 'theme-wallpaper: kitty colors written; open a new kitty window to see them.\n' >&2
  fi
  return 0
}

apply_tmux_theme() {
  local tmux_config="$CONFIG_HOME/tmux/tmux.conf"

  if ! command -v tmux >/dev/null 2>&1; then
    return 0
  fi

  if tmux source-file "$tmux_config" >/dev/null 2>&1; then
    printf 'Tmux: reloaded theme\n'
  else
    printf 'theme-wallpaper: tmux not reloaded; no reachable tmux server.\n' >&2
  fi
}

apply_hyprland_theme() {
  local active
  local inactive

  if ! command -v hyprctl >/dev/null 2>&1; then
    return 0
  fi

  active="$(awk -F= '$1 == "hyprland_active_border" { print $2 }' "$STATE_DIR/palette")"
  inactive="$(awk -F= '$1 == "hyprland_inactive_border" { print $2 }' "$STATE_DIR/palette")"

  if [[ -z "$active" || -z "$inactive" ]]; then
    printf 'theme-wallpaper: Hyprland colors missing from generated palette.\n' >&2
    return 0
  fi

  if hyprctl keyword general:col.active_border "$active" >/dev/null 2>&1 \
    && hyprctl keyword general:col.inactive_border "$inactive" >/dev/null 2>&1; then
    printf 'Hyprland: live border colors updated\n'
  else
    printf 'theme-wallpaper: Hyprland border colors written, but live update failed.\n' >&2
  fi
}

apply_quickshell_theme() {
  if ! command -v quickshell >/dev/null 2>&1; then
    return 0
  fi

  if quickshell list 2>/dev/null | grep -q '^Instance '; then
    quickshell kill >/dev/null 2>&1 || true
  fi

  if quickshell --daemonize >/dev/null 2>&1; then
    printf 'Quickshell: restarted with generated theme\n'
  else
    printf 'theme-wallpaper: failed to restart quickshell; run `quickshell` to inspect the error.\n' >&2
  fi
}

pick_wallpaper() {
  local -a wallpapers=()
  while IFS= read -r -d '' file; do
    wallpapers+=("$file")
  done < <(
    find "$WALLPAPER_DIR" -maxdepth 1 -type f \
      \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.webp' \) \
      -print0 2>/dev/null
  )

  if [[ ${#wallpapers[@]} -eq 0 ]]; then
    printf 'theme-wallpaper: no wallpapers found in %s\n' "$WALLPAPER_DIR" >&2
    exit 1
  fi

  printf '%s\n' "${wallpapers[RANDOM % ${#wallpapers[@]}]}"
}

if [[ $# -gt 1 ]]; then
  usage
  exit 2
fi

if ! command -v hyprctl >/dev/null 2>&1; then
  printf 'theme-wallpaper: hyprctl is required\n' >&2
  exit 1
fi

if [[ $# -eq 1 ]]; then
  IMAGE="$1"
else
  IMAGE="$(pick_wallpaper)"
fi

if [[ ! -f "$IMAGE" ]]; then
  printf 'theme-wallpaper: image not found: %s\n' "$IMAGE" >&2
  exit 1
fi

IMAGE="$(readlink -f "$IMAGE")"

mkdir -p "$THEME_DIR" "$STATE_DIR" "$(dirname "$HYPRLAND_THEME")" "$(dirname "$QUICKSHELL_THEME")"

python3 - "$IMAGE" "$KITTY_THEME" "$HYPRLAND_THEME" "$QUICKSHELL_THEME" "$STATE_DIR" <<'PY'
from __future__ import annotations

import colorsys
import os
import pathlib
import sys
from dataclasses import dataclass

try:
    from PIL import Image
except ImportError:
    print("theme-wallpaper: Python Pillow module is required", file=sys.stderr)
    sys.exit(1)


@dataclass(frozen=True)
class Color:
    r: int
    g: int
    b: int

    @property
    def hex(self) -> str:
        return f"#{self.r:02x}{self.g:02x}{self.b:02x}"

    def hls(self) -> tuple[float, float, float]:
        return colorsys.rgb_to_hls(self.r / 255, self.g / 255, self.b / 255)

    def luminance(self) -> float:
        def channel(value: int) -> float:
            value = value / 255
            return value / 12.92 if value <= 0.03928 else ((value + 0.055) / 1.055) ** 2.4

        return 0.2126 * channel(self.r) + 0.7152 * channel(self.g) + 0.0722 * channel(self.b)

    def contrast(self, other: "Color") -> float:
        lighter = max(self.luminance(), other.luminance())
        darker = min(self.luminance(), other.luminance())
        return (lighter + 0.05) / (darker + 0.05)

    def with_lightness(self, lightness: float) -> "Color":
        h, _l, s = self.hls()
        r, g, b = colorsys.hls_to_rgb(h, clamp(lightness), s)
        return Color(round(r * 255), round(g * 255), round(b * 255))

    def with_saturation(self, saturation: float) -> "Color":
        h, l, _s = self.hls()
        r, g, b = colorsys.hls_to_rgb(h, l, clamp(saturation))
        return Color(round(r * 255), round(g * 255), round(b * 255))

    def mix(self, other: "Color", amount: float) -> "Color":
        amount = clamp(amount)
        return Color(
            round(self.r * (1 - amount) + other.r * amount),
            round(self.g * (1 - amount) + other.g * amount),
            round(self.b * (1 - amount) + other.b * amount),
        )


def clamp(value: float, low: float = 0.0, high: float = 1.0) -> float:
    return min(high, max(low, value))


def useful_accent(color: Color) -> bool:
    _h, lightness, saturation = color.hls()
    return saturation >= 0.18 and 0.18 <= lightness <= 0.82


def brighten(color: Color) -> Color:
    h, l, s = color.hls()
    r, g, b = colorsys.hls_to_rgb(h, clamp(max(l + 0.18, 0.62)), clamp(max(s, 0.35)))
    return Color(round(r * 255), round(g * 255), round(b * 255))


def extract_colors(image_path: pathlib.Path) -> list[Color]:
    with Image.open(image_path) as image:
        image = image.convert("RGB")
        image.thumbnail((260, 260))
        quantized = image.quantize(colors=18, method=Image.Quantize.MEDIANCUT)
        palette = quantized.getpalette() or []
        counts = quantized.getcolors() or []

    weighted: list[tuple[int, Color]] = []
    for count, index in counts:
        offset = index * 3
        if offset + 2 < len(palette):
            weighted.append((count, Color(palette[offset], palette[offset + 1], palette[offset + 2])))

    weighted.sort(key=lambda item: item[0], reverse=True)
    return [color for _count, color in weighted]


def palette_from(colors: list[Color]) -> dict[str, Color]:
    if not colors:
        raise ValueError("no colors could be extracted from image")

    darkest = min(colors, key=lambda c: c.luminance())
    lightest = max(colors, key=lambda c: c.luminance())
    accents = [color for color in colors if useful_accent(color)] or colors
    accents = sorted(accents, key=lambda c: c.hls()[2], reverse=True)

    background = darkest.with_lightness(0.07).with_saturation(max(darkest.hls()[2], 0.22))
    foreground = lightest.with_lightness(0.91).with_saturation(min(lightest.hls()[2], 0.28))
    if background.contrast(foreground) < 7:
        foreground = Color(238, 242, 245)

    primary = accents[0].with_lightness(0.50).with_saturation(max(accents[0].hls()[2], 0.35))
    secondary = accents[min(1, len(accents) - 1)].with_lightness(0.46).with_saturation(0.38)
    accent = accents[min(2, len(accents) - 1)].with_lightness(0.58).with_saturation(0.48)
    muted = foreground.mix(background, 0.48)
    bg_alt = background.mix(primary, 0.18)

    return {
        "foreground": foreground,
        "background": background,
        "cursor": accent,
        "selection_foreground": background,
        "selection_background": accent,
        "active_border_color": primary,
        "inactive_border_color": bg_alt,
        "active_tab_foreground": background,
        "active_tab_background": primary,
        "inactive_tab_foreground": muted,
        "inactive_tab_background": bg_alt,
        "color0": background,
        "color1": Color(229, 87, 93),
        "color2": Color(85, 195, 112),
        "color3": Color(226, 178, 78),
        "color4": secondary,
        "color5": primary,
        "color6": accent,
        "color7": foreground,
        "color8": muted,
        "color9": brighten(Color(229, 87, 93)),
        "color10": brighten(Color(85, 195, 112)),
        "color11": brighten(Color(226, 178, 78)),
        "color12": brighten(secondary),
        "color13": brighten(primary),
        "color14": brighten(accent),
        "color15": Color(248, 250, 252),
    }


def write_atomic(path: pathlib.Path, content: str) -> None:
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(content, encoding="utf-8")
    os.replace(tmp, path)


def qml_rgba(color: Color, alpha: float) -> str:
    return f"Qt.rgba({color.r / 255:.4f}, {color.g / 255:.4f}, {color.b / 255:.4f}, {alpha:.2f})"


def hypr_rgba(color: Color, alpha: str) -> str:
    return f"rgba({color.hex[1:]}{alpha})"


def hyprland_border_colors(colors: dict[str, Color]) -> tuple[str, str]:
    active = f"{hypr_rgba(colors['active_border_color'], 'd9')} {hypr_rgba(colors['background'], 'd9')} 45deg"
    inactive = hypr_rgba(colors["inactive_border_color"], "aa")
    return active, inactive


def render_hyprland_theme(colors: dict[str, Color]) -> str:
    active, inactive = hyprland_border_colors(colors)
    return f"""# Generated by theme-wallpaper. Do not edit.

general {{
    col.active_border = {active}
    col.inactive_border = {inactive}
}}
"""


def render_quickshell_theme(colors: dict[str, Color]) -> str:
    return f"""// Generated by theme-wallpaper. Do not edit.
import QtQuick

QtObject {{
    readonly property color bg: "{colors["background"].hex}"
    readonly property color bgAlt: "{colors["inactive_tab_background"].hex}"
    readonly property color panel: {qml_rgba(colors["background"].mix(colors["color5"], 0.18), 0.90)}
    readonly property color panelStrong: {qml_rgba(colors["background"].mix(colors["color5"], 0.18), 0.96)}
    readonly property color fg: "{colors["foreground"].hex}"
    readonly property color muted: "{colors["color8"].hex}"
    readonly property color subtle: "{colors["color12"].hex}"
    readonly property color primary: "{colors["color5"].hex}"
    readonly property color accent: "{colors["color6"].hex}"
    readonly property color warning: "{colors["color3"].hex}"
    readonly property color error: "{colors["color1"].hex}"
}}
"""


def main() -> int:
    image_path = pathlib.Path(sys.argv[1])
    kitty_theme = pathlib.Path(sys.argv[2])
    hyprland_theme = pathlib.Path(sys.argv[3])
    quickshell_theme = pathlib.Path(sys.argv[4])
    state_dir = pathlib.Path(sys.argv[5])

    colors = palette_from(extract_colors(image_path))
    hyprland_active, hyprland_inactive = hyprland_border_colors(colors)
    lines = [
        "# Generated by theme-wallpaper. Do not edit.",
        f"# Source image: {image_path}",
        "",
    ]
    for key, color in colors.items():
        lines.append(f"{key} {color.hex}")
    lines.append("")

    write_atomic(kitty_theme, "\n".join(lines))
    write_atomic(hyprland_theme, render_hyprland_theme(colors))
    write_atomic(quickshell_theme, render_quickshell_theme(colors))
    (state_dir / "current-wallpaper").write_text(str(image_path) + "\n", encoding="utf-8")
    (state_dir / "palette").write_text(
        "\n".join(
            [f"{key}={color.hex}" for key, color in colors.items()]
            + [
                f"hyprland_active_border={hyprland_active}",
                f"hyprland_inactive_border={hyprland_inactive}",
            ]
        )
        + "\n",
        encoding="utf-8",
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
PY

set_wallpaper "$IMAGE" || true

apply_kitty_colors
apply_hyprland_theme
apply_tmux_theme
apply_quickshell_theme

printf 'Wallpaper: %s\n' "$IMAGE"
printf 'Kitty theme: %s\n' "$KITTY_THEME"
printf 'Hyprland theme: %s\n' "$HYPRLAND_THEME"
printf 'Quickshell theme: %s\n' "$QUICKSHELL_THEME"
